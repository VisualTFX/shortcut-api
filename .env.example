# ── Domain ──────────────────────────────────────────────
ALIAS_DOMAIN=mail-one4all.uk
ALIAS_LENGTH=12
# All lowercase letters/digits except ambiguous l, 1, o, 0
ALIAS_CHARSET=abcdefghjkmnpqrstuvwxyz23456789
ALIAS_PREFIX=
ALIAS_SUFFIX=

# ── Session ──────────────────────────────────────────────
SESSION_TTL_SECONDS=600

# ── Database ─────────────────────────────────────────────
# SQLite (local dev / Windows)
DATABASE_URL=sqlite+aiosqlite:///./shortcut_api.db
# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/shortcut_api

# ── Gmail ────────────────────────────────────────────────
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GMAIL_MONITORED_LABEL=INBOX
# "polling" or "watch"
GMAIL_STRATEGY=polling
GMAIL_POLL_INTERVAL_SECONDS=10

# ── Security ─────────────────────────────────────────────
ADMIN_TOKEN=change-me-to-a-secure-random-token
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── Retention ────────────────────────────────────────────
RETENTION_ENABLED=false
RETENTION_REDACT_BODY=true
RETENTION_DAYS=7

# ── Recycle ──────────────────────────────────────────────
RECYCLE_ENABLED=false

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
